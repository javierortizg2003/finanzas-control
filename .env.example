# FinanzasControl - Variables de entorno
# Copia este archivo como .env y configura tu base de datos

# Base de datos PostgreSQL
# Opciones:
#   - Vercel Postgres (recomendado): se configura automáticamente al agregar Vercel Storage
#   - Neon.tech (gratis): https://neon.tech
#   - Supabase (gratis): https://supabase.com
#   - Local: postgresql://usuario:password@localhost:5432/finanzas_control

DATABASE_URL="postgresql://usuario:password@localhost:5432/finanzas_control"
